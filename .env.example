DATABASE_MONGODB_URI=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Optional: only required when you want uploads to use Vercel Blob.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx

# Optional: comma-separated origins that can call Payload automation endpoints, such as n8n.
N8N_ALLOWED_ORIGINS=http://localhost:5678
